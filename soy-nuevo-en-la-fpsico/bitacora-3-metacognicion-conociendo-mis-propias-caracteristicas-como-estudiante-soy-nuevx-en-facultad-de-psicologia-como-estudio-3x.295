       {"src":"https://i.imgur.com/gORGIUf.png","href":"https://wa.me/59898053967/?text=Hola!%20Me%20interesa%20el%20descuento%20de%20herramientas%20de%20la%20psicolog%C3%ADa%20social%20y%20herramientas%20de%20la%20psicolog%C3%ADa%20cl%C3%ADnica.%20Quiero%20m%C3%A1s%20informaci%C3%B3n"},
       {"src":"https://i.imgur.com/wznL8HR.png","href":"https://wa.me/59898053967/?text=Hola!%20Me%20interesan%20las%20tutor%C3%ADas%20de%20psicopatolog%C3%ADa%20cl%C3%ADnica%20de%20adultos.%20Quiero%20m%C3%A1s%20informaci%C3%B3n"},
       {"src":"https://i.imgur.com/WGMtekJ.png","href":"https://wa.me/59898053967/?text=Hola!%20Me%20interesan%20las%20tutor%C3%ADas%20de%20articulaci%C3%B3n%20de%20saberes%205.%20Quiero%20m%C3%A1s%20informaci%C3%B3n"},
       {"src":"https://i.imgur.com/miXuj5I.png","href":"https://wa.me/59898053967/?text=Hola!%20Me%20interesa%20el%20descuento%20de%20los%20parciales%20de%20psicopatolog%C3%ADa%20cl%C3%ADnica%20de%20adultos%20y%20articulaci%C3%B3n%20de%20saberes%205.%20Quiero%20m%C3%A1s%20informaci%C3%B3n"}       
     ]'
     data-interval="4000"
     data-max="350"
     data-fit="cover"
     data-per-view="3">
</div>

<script>
(async function(){
  const host = document.getElementById('psr-carousel-widget');
  if (!host) return;

  // Config
  const IMAGES   = (()=>{ try{ return JSON.parse(host.getAttribute('data-images')||'[]'); }catch(e){ return []; }})();
  const INTERVAL = Math.max(500, parseInt(host.getAttribute('data-interval')||'2000',10));
  const MAX      = parseInt(host.getAttribute('data-max')||'350',10);
  const FIT      = (host.getAttribute('data-fit')||'cover').trim();
  const PER_VIEW = Math.max(1, parseInt(host.getAttribute('data-per-view')||'3',10));

  // ---- Precarga ----
  const preload = (urls)=> Promise.all(urls.map(u => new Promise(res => {
    const url = (typeof u === 'string') ? u : u.src;
    const im = new Image();
    im.referrerPolicy = 'no-referrer';
    im.src = url;
    if (im.complete) return res();
    im.onload = im.onerror = res;
  })));
  const SRC_LIST = IMAGES.map(u => (typeof u === 'string') ? u : u.src);
  await preload(SRC_LIST.slice(0, Math.min(SRC_LIST.length, PER_VIEW + 2)));
  preload(SRC_LIST);

  // Shadow DOM
  const shadow = host.attachShadow({mode:'open'});
  shadow.innerHTML = `
    <style>
      :host{ all: initial; }
      :host{
        --card-max: ${MAX}px;
        --img-fit: ${FIT};
        --per-view: ${PER_VIEW};
        --per-view-current: ${PER_VIEW};
        --gap: 10px;
        --radius: 14px;
        --shadow: 0 6px 20px rgba(0,0,0,.08);
        --border: 1px solid rgba(0,0,0,.08);
        --transition: 1500ms ease;

        --ctrl-size: 44px;
        --ctrl-gap: 12px;
        --ctrl-fill:  #b1b1b1;  /* círculo */
        --ctrl-border:#b1b1b1;  /* borde */
        --ctrl-arrow: #f2f2f2;  /* flecha */
      }

      @media (max-width: 480px){
        :host{ --img-fit: contain; } /* igual son cuadradas; esto evita recortes si hubiera bordes */
      }

      .carousel{
        width:100%;
        display:flex;
        align-items:center;
        justify-content:center;
        gap: var(--ctrl-gap);
        padding:8px;
        box-sizing:border-box;
        font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      }

      .carousel-viewport{
        width: min(100%, calc(var(--card-max) * var(--per-view-current)));
        /* altura cuadrada la fija JS (no usamos aspect-ratio aquí) */
        overflow:hidden;
        border-radius:var(--radius);
        position:relative;
        cursor:grab;
        touch-action:pan-y;
      }
      .carousel-viewport.grabbing{ cursor:grabbing; }

      .carousel-track{
        display:flex;
        height:100%;
        will-change:transform;
        transition:transform var(--transition);
        gap: var(--gap);
        box-sizing:border-box;
        transform: translateZ(0);
      }

      .card{
        flex: 0 0 calc((100% - (var(--gap) * (var(--per-view-current) - 1))) / var(--per-view-current));
        width:     calc((100% - (var(--gap) * (var(--per-view-current) - 1))) / var(--per-view-current));
        aspect-ratio: 1 / 1; /* tarjetas cuadradas */
        background:#fff;
        border-radius:var(--radius);
        box-shadow:var(--shadow);
        border:var(--border);
        overflow:hidden;
        backface-visibility: hidden;
        transform: translateZ(0);
      }
      .card a{ display:block; width:100%; height:100%; }
      .card img{
        width:100%; height:100%; object-fit:var(--img-fit); display:block;
        -webkit-user-drag:none; user-select:none;
        backface-visibility: hidden; transform: translateZ(0);
      }

      .ctrl{
        width:var(--ctrl-size);
        height:var(--ctrl-size);
        display:grid;
        place-items:center;
        border:none;
        background:transparent;
        padding:0;
        margin:0;
        cursor:pointer;
        outline:none;
      }
      .ctrl:focus-visible { outline:2px solid #0a396588; outline-offset:2px; border-radius:999px; }
      .icon{
        width:100%; height:100%; display:block;
        filter: drop-shadow(0 2px 6px rgba(0,0,0,.2));
        transition: transform 180ms ease;
      }
      .ctrl:hover .icon{ transform: scale(1.06); }

      @media (prefers-reduced-motion: reduce){
        .carousel-track{ transition:none; }
        .icon{ transition:none; }
      }
    </style>

    <div class="carousel" role="group" aria-roledescription="carousel" aria-label="Carrusel">
      <!-- Flecha izquierda -->
      <button class="ctrl ctrl-left"  aria-label="Anterior" type="button">
        <svg class="icon" viewBox="0 0 48 48" aria-hidden="true">
          <circle cx="24" cy="24" r="22" fill="var(--ctrl-fill)" stroke="var(--ctrl-border)" stroke-width="3"/>
          <path d="M27.5 15 L18 24 L27.5 33" fill="none" stroke="var(--ctrl-arrow)"
                stroke-width="3.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <!-- Viewport -->
      <div class="carousel-viewport" tabindex="0">
        <div class="carousel-track"></div>
      </div>

      <!-- Flecha derecha -->
      <button class="ctrl ctrl-right" aria-label="Siguiente" type="button">
        <svg class="icon" viewBox="0 0 48 48" aria-hidden="true">
          <circle cx="24" cy="24" r="22" fill="var(--ctrl-fill)" stroke="var(--ctrl-border)" stroke-width="3"/>
          <path d="M20.5 15 L30 24 L20.5 33" fill="none" stroke="var(--ctrl-arrow)"
                stroke-width="3.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  `;

  const viewport = shadow.querySelector('.carousel-viewport');
  const track = shadow.querySelector('.carousel-track');
  const btnPrev = shadow.querySelector('.ctrl-left');
  const btnNext = shadow.querySelector('.ctrl-right');

  // Slides reales
  const realSlides = IMAGES.map((item, i)=>{
    const data = (typeof item === 'string') ? {src: item, href: '#'} : item;
    const art = document.createElement('article');
    art.className = 'card';
    art.setAttribute('role','group');

    const a = document.createElement('a');
    a.href = data.href || '#';
    a.target = "_blank";
    a.rel = "noopener noreferrer";

    const img = document.createElement('img');
    img.src = data.src;
    img.alt = '';
    img.referrerPolicy = 'no-referrer';
    if (i < PER_VIEW + 1) img.setAttribute('fetchpriority','high');

    a.appendChild(img);
    art.appendChild(a);
    return art;
  });
  if (!realSlides.length) { track.textContent = 'Configura data-images con al menos una URL de imagen.'; return; }
  const N = realSlides.length;

  // Montaje: reales + clones
  realSlides.forEach(s=>track.appendChild(s));
  for (let i=0;i<Math.min(PER_VIEW,N);i++){
    const c = realSlides[i].cloneNode(true);
    c.setAttribute('aria-hidden','true');
    track.appendChild(c);
  }
  const before = realSlides.slice(-Math.min(PER_VIEW,N));
  for (let i=before.length-1;i>=0;i--){
    const c = before[i].cloneNode(true);
    c.setAttribute('aria-hidden','true');
    track.insertBefore(c, track.firstChild);
  }

  // Estado
  let index = PER_VIEW;
  let slideStep = 0;
  let gapPx = 0;
  let timer = null;
  let perViewCurrent = PER_VIEW;

  // Helpers
  const pxFromCSS = (v)=> Number(String(v).replace('px','')) || 0;

  function computePerView(){
    const w = (host.getBoundingClientRect().width || window.innerWidth);
    let pv = PER_VIEW;
    if (w <= 480) pv = 1;
    else if (w <= 900) pv = Math.min(2, PER_VIEW);
    else pv = PER_VIEW;
    if (pv !== perViewCurrent){
      perViewCurrent = pv;
      shadow.host.style.setProperty('--per-view-current', String(perViewCurrent));
    }
  }

  // □ Fuerza viewport cuadrado (alto = ancho medido)
  // □ Reemplazá tu squareViewport() por esta versión:
function squareViewport() {
  // ancho total disponible del viewport
  const vw = viewport.clientWidth || host.clientWidth || 0;

  // per-view actual (1, 2 o 3)
  const pv = Number(getComputedStyle(shadow.host).getPropertyValue('--per-view-current')) || 1;

  // gap entre tarjetas (px)
  const gapStr = getComputedStyle(shadow.querySelector('.carousel-track')).gap || '0px';
  const gap = parseFloat(gapStr) || 0;

  // ancho de UNA tarjeta: (ancho viewport - gaps) / pv
  const cardWidth = pv > 1 ? (vw - gap * (pv - 1)) / pv : vw;

  // fijar alto del viewport al ancho de una tarjeta (cuadrado real)
  viewport.style.height = cardWidth > 0 ? (cardWidth + 'px') : '';

  // al cambiar la altura, recalculamos medidas y reposicionamos
  measureStep();
  goto(index, false);
}


  function measureStep(){
    const card = track.querySelector('.card');
    const rect = card ? card.getBoundingClientRect() : {width: (viewport.clientWidth || host.clientWidth) / perViewCurrent};
    gapPx = pxFromCSS(getComputedStyle(track).gap);
    slideStep = rect.width + gapPx;
  }

  function updateFetchPriority(i){
    const start = i, end = i + perViewCurrent + 1;
    const slides = Array.from(track.querySelectorAll('.card img'));
    slides.forEach((img, k)=>{
      if (k >= start && k <= end) img.setAttribute('fetchpriority','high');
      else img.removeAttribute('fetchpriority');
    });
  }

  function goto(i, withTransition=true){
    track.style.transition = withTransition ? 'transform var(--transition)' : 'none';
    track.style.transform = `translateX(-${i * slideStep}px)`;
    updateFetchPriority(i);
  }

  function next(){ index++; goto(index, true); }
  function prev(){ index--; goto(index, true); }

  track.addEventListener('transitionend', ()=>{
    const maxIndex = N + PER_VIEW;
    if (index >= maxIndex){ index = PER_VIEW; goto(index, false); }
    else if (index < PER_VIEW){ index = N + index; goto(index, false); }
  });

  function start(){ stop(); timer = setInterval(next, INTERVAL); }
  function stop(){ if (timer){ clearInterval(timer); timer = null; } }

  // Drag
  let dragging = false, startX = 0, startTX = 0, moved = false;
  const currentTX = ()=> {
    const m = /translateX\((-?\d+(?:\.\d+)?)px\)/.exec(track.style.transform);
    return m ? parseFloat(m[1]) : -(index * slideStep);
  };

  function down(x){ dragging=true; moved=false; viewport.classList.add('grabbing'); stop(); track.style.transition='none'; startX=x; startTX=currentTX(); }
  function move(x){ if(!dragging) return; const dx=x-startX; if (Math.abs(dx)>5) moved=true; track.style.transform=`translateX(${startTX+dx}px)`; }
  function up(x){ if(!dragging) return; dragging=false; viewport.classList.remove('grabbing'); const dx=x-startX; const th=Math.max(slideStep*0.15,60); if (Math.abs(dx)>5) moved=true; if(dx<=-th) index++; else if(dx>=th) index--; goto(index,true); start(); }

  viewport.addEventListener('mousedown', e=>{ e.preventDefault(); down(e.clientX); });
  shadow.addEventListener('mousemove',  e=> move(e.clientX));
  shadow.addEventListener('mouseup',    e=> up(e.clientX));
  viewport.addEventListener('mouseleave', e=>{ if (dragging) up(e.clientX || startX); });

  viewport.addEventListener('touchstart', e=> down(e.touches[0].clientX), {passive:true});
  viewport.addEventListener('touchmove',  e=> move(e.touches[0].clientX), {passive:true});
  viewport.addEventListener('touchend',   e=> up((e.changedTouches[0]||{}).clientX ?? startX), {passive:true});

  viewport.addEventListener('mouseenter', stop);
  viewport.addEventListener('mouseleave', start);
  viewport.addEventListener('focusin', stop);
  viewport.addEventListener('focusout', start);

  // Guard anti-click
  shadow.addEventListener('click', (e) => {
    const path = e.composedPath ? e.composedPath() : [];
    const anchor = path.find(el => el instanceof HTMLAnchorElement);
    if (anchor && (dragging || moved)) {
      e.preventDefault();
      e.stopPropagation();
      moved = false;
    }
  }, true);

  // Botones
  btnPrev.addEventListener('click', () => { stop(); prev(); start(); });
  btnNext.addEventListener('click', () => { stop(); next(); start(); });

  // Teclado
  viewport.addEventListener('keydown', (e)=>{
    if (e.key==='ArrowLeft'){ e.preventDefault(); stop(); prev(); start(); }
    if (e.key==='ArrowRight'){ e.preventDefault(); stop(); next(); start(); }
  });

  // Resize: recalcular per-view y asegurar cuadrado
  addEventListener('resize', ()=>{
    const wasRunning=!!timer;
    stop();
    computePerView();
    squareViewport(); // fija alto = ancho y recalcula paso
    if(wasRunning) start();
  });

  // Init
  computePerView();
  squareViewport();  // fija altura y medidas, y posiciona
  start();
})();
</script>
</div>



