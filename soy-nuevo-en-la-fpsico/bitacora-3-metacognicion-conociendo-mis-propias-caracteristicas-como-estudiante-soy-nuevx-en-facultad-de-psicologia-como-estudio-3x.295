            box-shadow: 5px 5px 10px rgba(0, 0, 0, 0.1), -5px 5px 10px rgba(0, 0, 0, 0.1); /* Añade una sombra difuminada a la derecha, izquierda y abajo */
            border-radius: 0 0 5px 5px; /* Solo los bordes inferiores tendrán el radio redondeado */
