      </button>
    </div>
  `;

  const viewport = shadow.querySelector('.carousel-viewport');
  const track = shadow.querySelector('.carousel-track');
  const btnPrev = shadow.querySelector('.ctrl-left');
  const btnNext = shadow.querySelector('.ctrl-right');

  // Slides reales
  const realSlides = IMAGES.map((item, i)=>{
    const data = (typeof item === 'string') ? {src: item, href: '#'} : item;
    const art = document.createElement('article');
    art.className = 'card';
    art.setAttribute('role','group');

    const a = document.createElement('a');
    a.href = data.href || '#';
    a.target = "_blank";
    a.rel = "noopener noreferrer";

    const img = document.createElement('img');
    img.src = data.src;
    img.alt = '';
    img.referrerPolicy = 'no-referrer';
    if (i < PER_VIEW + 1) img.setAttribute('fetchpriority','high');

    a.appendChild(img);
    art.appendChild(a);
    return art;
  });
  if (!realSlides.length) { track.textContent = 'Configura data-images con al menos una URL de imagen.'; return; }
  const N = realSlides.length;

  // Montaje: reales + clones
  realSlides.forEach(s=>track.appendChild(s));
  for (let i=0;i<Math.min(PER_VIEW,N);i++){
    const c = realSlides[i].cloneNode(true);
    c.setAttribute('aria-hidden','true');
    track.appendChild(c);
  }
  const before = realSlides.slice(-Math.min(PER_VIEW,N));
  for (let i=before.length-1;i>=0;i--){
    const c = before[i].cloneNode(true);
    c.setAttribute('aria-hidden','true');
    track.insertBefore(c, track.firstChild);
  }

  // Estado
  let index = PER_VIEW;
  let slideStep = 0;
  let gapPx = 0;
  let timer = null;
  let perViewCurrent = PER_VIEW;

  // Helpers
  const pxFromCSS = (v)=> Number(String(v).replace('px','')) || 0;

  function computePerView(){
    const w = (host.getBoundingClientRect().width || window.innerWidth);
    let pv = PER_VIEW;
    if (w <= 480) pv = 1;
    else if (w <= 900) pv = Math.min(2, PER_VIEW);
    else pv = PER_VIEW;
    if (pv !== perViewCurrent){
      perViewCurrent = pv;
      shadow.host.style.setProperty('--per-view-current', String(perViewCurrent));
    }
  }

  // □ Fuerza viewport cuadrado (alto = ancho medido)
  // □ Reemplazá tu squareViewport() por esta versión:
function squareViewport() {
  // ancho total disponible del viewport
  const vw = viewport.clientWidth || host.clientWidth || 0;

  // per-view actual (1, 2 o 3)
  const pv = Number(getComputedStyle(shadow.host).getPropertyValue('--per-view-current')) || 1;

  // gap entre tarjetas (px)
  const gapStr = getComputedStyle(shadow.querySelector('.carousel-track')).gap || '0px';
  const gap = parseFloat(gapStr) || 0;

  // ancho de UNA tarjeta: (ancho viewport - gaps) / pv
  const cardWidth = pv > 1 ? (vw - gap * (pv - 1)) / pv : vw;

  // fijar alto del viewport al ancho de una tarjeta (cuadrado real)
  viewport.style.height = cardWidth > 0 ? (cardWidth + 'px') : '';

  // al cambiar la altura, recalculamos medidas y reposicionamos
  measureStep();
  goto(index, false);
}


  function measureStep(){
    const card = track.querySelector('.card');
    const rect = card ? card.getBoundingClientRect() : {width: (viewport.clientWidth || host.clientWidth) / perViewCurrent};
    gapPx = pxFromCSS(getComputedStyle(track).gap);
    slideStep = rect.width + gapPx;
  }

  function updateFetchPriority(i){
    const start = i, end = i + perViewCurrent + 1;
    const slides = Array.from(track.querySelectorAll('.card img'));
    slides.forEach((img, k)=>{
      if (k >= start && k <= end) img.setAttribute('fetchpriority','high');
      else img.removeAttribute('fetchpriority');
    });
  }

  function goto(i, withTransition=true){
    track.style.transition = withTransition ? 'transform var(--transition)' : 'none';
    track.style.transform = `translateX(-${i * slideStep}px)`;
    updateFetchPriority(i);
  }

  function next(){ index++; goto(index, true); }
  function prev(){ index--; goto(index, true); }

  track.addEventListener('transitionend', ()=>{
    const maxIndex = N + PER_VIEW;
    if (index >= maxIndex){ index = PER_VIEW; goto(index, false); }
    else if (index < PER_VIEW){ index = N + index; goto(index, false); }
  });

  function start(){ stop(); timer = setInterval(next, INTERVAL); }
  function stop(){ if (timer){ clearInterval(timer); timer = null; } }

  // Drag
  let dragging = false, startX = 0, startTX = 0, moved = false;
  const currentTX = ()=> {
    const m = /translateX\((-?\d+(?:\.\d+)?)px\)/.exec(track.style.transform);
    return m ? parseFloat(m[1]) : -(index * slideStep);
  };

  function down(x){ dragging=true; moved=false; viewport.classList.add('grabbing'); stop(); track.style.transition='none'; startX=x; startTX=currentTX(); }
  function move(x){ if(!dragging) return; const dx=x-startX; if (Math.abs(dx)>5) moved=true; track.style.transform=`translateX(${startTX+dx}px)`; }
  function up(x){ if(!dragging) return; dragging=false; viewport.classList.remove('grabbing'); const dx=x-startX; const th=Math.max(slideStep*0.15,60); if (Math.abs(dx)>5) moved=true; if(dx<=-th) index++; else if(dx>=th) index--; goto(index,true); start(); }

  viewport.addEventListener('mousedown', e=>{ e.preventDefault(); down(e.clientX); });
  shadow.addEventListener('mousemove',  e=> move(e.clientX));
  shadow.addEventListener('mouseup',    e=> up(e.clientX));
  viewport.addEventListener('mouseleave', e=>{ if (dragging) up(e.clientX || startX); });

  viewport.addEventListener('touchstart', e=> down(e.touches[0].clientX), {passive:true});
  viewport.addEventListener('touchmove',  e=> move(e.touches[0].clientX), {passive:true});
  viewport.addEventListener('touchend',   e=> up((e.changedTouches[0]||{}).clientX ?? startX), {passive:true});

  viewport.addEventListener('mouseenter', stop);
  viewport.addEventListener('mouseleave', start);
  viewport.addEventListener('focusin', stop);
  viewport.addEventListener('focusout', start);

  // Guard anti-click
  shadow.addEventListener('click', (e) => {
    const path = e.composedPath ? e.composedPath() : [];
    const anchor = path.find(el => el instanceof HTMLAnchorElement);
    if (anchor && (dragging || moved)) {
      e.preventDefault();
      e.stopPropagation();
      moved = false;
    }
  }, true);

  // Botones
  btnPrev.addEventListener('click', () => { stop(); prev(); start(); });
  btnNext.addEventListener('click', () => { stop(); next(); start(); });

  // Teclado
  viewport.addEventListener('keydown', (e)=>{
    if (e.key==='ArrowLeft'){ e.preventDefault(); stop(); prev(); start(); }
    if (e.key==='ArrowRight'){ e.preventDefault(); stop(); next(); start(); }
  });

  // Resize: recalcular per-view y asegurar cuadrado
  addEventListener('resize', ()=>{
    const wasRunning=!!timer;
    stop();
    computePerView();
    squareViewport(); // fija alto = ancho y recalcula paso
    if(wasRunning) start();
  });

  // Init
  computePerView();
  squareViewport();  // fija altura y medidas, y posiciona
  start();
})();
