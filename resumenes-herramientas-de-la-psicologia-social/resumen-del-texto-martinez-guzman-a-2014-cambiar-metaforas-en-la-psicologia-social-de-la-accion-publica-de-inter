      <!-- Flecha izquierda -->
      <button class="ctrl ctrl-left"  aria-label="Anterior" type="button">
        <svg class="icon" viewBox="0 0 48 48" aria-hidden="true">
          <circle cx="24" cy="24" r="22" fill="var(--ctrl-fill)" stroke="var(--ctrl-border)" stroke-width="3"/>
          <path d="M27.5 15 L18 24 L27.5 33" fill="none" stroke="var(--ctrl-arrow)"
                stroke-width="3.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <!-- Viewport -->
      <div class="carousel-viewport" tabindex="0">
        <div class="carousel-track"></div>
      </div>

      <!-- Flecha derecha -->
      <button class="ctrl ctrl-right" aria-label="Siguiente" type="button">
        <svg class="icon" viewBox="0 0 48 48" aria-hidden="true">
          <circle cx="24" cy="24" r="22" fill="var(--ctrl-fill)" stroke="var(--ctrl-border)" stroke-width="3"/>
          <path d="M20.5 15 L30 24 L20.5 33" fill="none" stroke="var(--ctrl-arrow)"
                stroke-width="3.2" stroke-linecap="round" stroke-linejoin="round"/>
