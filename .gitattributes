# Auto detect text files and perform LF normalization
* text=auto

# Fuentes: tratar siempre como binario (evita corrupción por normalización de saltos de línea)
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary

# Imágenes: binario
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
